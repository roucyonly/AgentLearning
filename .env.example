# AgentLearning 环境变量配置示例
# 复制此文件为 .env 并填入真实 API Key

# ==================== 当前激活的厂商 ====================
ACTIVE_LLM=openai        # openai / anthropic / zhipu / deepseek / siliconflow
ACTIVE_TTS=edge         # edge / elevenlabs / minimax
ACTIVE_SEARCH=duckduckgo # duckduckgo / serpapi / serper / tavily

# ==================== LLM Keys ====================
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-xxxx

ZHIPU_API_KEY=xxxx

DEEPSEEK_API_KEY=sk-xxxx

SILICONFLOW_API_KEY=sk-xxxx

# ==================== TTS Keys ====================
EDGE_TTS_KEY=xxxx
ELEVENLABS_API_KEY=xxxx
MINIMAX_API_KEY=xxxx

# ==================== Search Keys ====================
SERPAPI_API_KEY=xxxx
SERPER_API_KEY=xxxx
TAVILY_API_KEY=xxxx
