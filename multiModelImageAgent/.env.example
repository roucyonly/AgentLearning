# 应用配置
APP_NAME=MultiModel Image Agent
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# 数据库 (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./multimodel.db

# Redis (可选)
REDIS_URL=redis://localhost:6379/0

# LLM API (用于 Agent)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Volcengine Doubao API (用于图像生成)
ARK_API_KEY=ark-...

# 加密
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# 日志
LOG_LEVEL=INFO
