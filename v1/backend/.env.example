# ========================================
# 轻量级配置 (SQLite + Chroma) - 推荐用于开发
# ========================================

# 数据库配置
DATABASE_URL=sqlite:///./teacher_avatar.db

# 向量数据库选择
VECTOR_STORE_TYPE=chroma

# LLM 配置 (选择一个)
ACTIVE_LLM=openai
OPENAI_API_KEY=sk-your-openai-key-here

# 或者使用 DeepSeek (更便宜)
# ACTIVE_LLM=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 或者使用 SiliconFlow (免费额度)
# ACTIVE_LLM=siliconflow
# SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# 安全配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LangSmith 追踪 (可选)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=teacher-avatar

# 文件上传
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Redis (可选,用于缓存)
# REDIS_URL=redis://localhost:6379/0

# ========================================
# 生产级配置 (PostgreSQL + Milvus)
# ========================================

# 如果要使用 PostgreSQL,取消下面的注释:
# DATABASE_URL=postgresql://postgres:your-password@localhost:5432/teacher_avatar

# 如果要使用 Milvus,取消下面的注释:
# VECTOR_STORE_TYPE=milvus
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
